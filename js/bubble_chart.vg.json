{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 380,
  "config": {
    "background": "transparent",
    "view": { "stroke": "transparent" },
    "axis": {
      "labelColor": "#c8c0b0",
      "titleColor": "#c8c0b0",
      "gridColor":  "#2a2a3e",
      "domainColor": "#3a3a5e"
    },
    "legend": { "labelColor": "#c8c0b0", "titleColor": "#c8c0b0" }
  },
  "data": { "url": "js/medals_data.csv", "format": { "type": "csv" } },
  "params": [
    {
      "name": "continent_select",
      "select": { "type": "point", "fields": ["continent"] },
      "bind": "legend"
    }
  ],
  "transform": [{ "filter": "datum.summer_total > 0" }],
  "mark": { "type": "circle", "opacity": 0.75 },
  "encoding": {
    "x": {
      "field": "summer_total",
      "type": "quantitative",
      "scale": { "type": "log", "base": 10 },
      "axis": { "title": "Total Summer Medals (log scale)", "format": "d" }
    },
    "y": {
      "field": "winter_total",
      "type": "quantitative",
      "scale": { "type": "sqrt", "domain": [0, 420] },
      "axis": { "title": "Total Winter Medals", "format": "d" }
    },
    "size": {
      "field": "total_medals",
      "type": "quantitative",
      "scale": { "range": [40, 1600] },
      "legend": { "title": "Total Medals" }
    },
    "color": {
      "field": "continent",
      "type": "nominal",
      "scale": {
        "domain": ["Americas", "Europe", "Asia", "Africa", "Oceania"],
        "range": ["#e76f51", "#2a9d8f", "#e9c46a", "#f4a261", "#264653"]
      },
      "legend": { "title": "Continent" }
    },
    "opacity": {
      "condition": { "param": "continent_select", "value": 0.85 },
      "value": 0.15
    },
    "tooltip": [
      { "field": "country",      "type": "nominal",      "title": "Country" },
      { "field": "continent",    "type": "nominal",      "title": "Continent" },
      { "field": "summer_total", "type": "quantitative", "title": "Summer Medals" },
      { "field": "winter_total", "type": "quantitative", "title": "Winter Medals" },
      { "field": "total_medals", "type": "quantitative", "title": "All-Time Total" }
    ]
  }
}
