{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 220,
  "config": {
    "background": "transparent",
    "view": { "stroke": "transparent" },
    "axis": {
      "labelColor": "#c8c0b0",
      "titleColor": "#c8c0b0",
      "gridColor":  "#2a2a3e",
      "domainColor": "#3a3a5e"
    },
    "legend": { "labelColor": "#c8c0b0", "titleColor": "#c8c0b0" }
  },
  "data": { "url": "js/host_data.csv", "format": { "type": "csv" } },
  "transform": [
    { "calculate": "floor(datum.year / 10) * 10", "as": "decade" },
    { "aggregate": [{ "op": "count", "as": "games_count" }], "groupby": ["continent", "decade"] }
  ],
  "mark": { "type": "rect", "cornerRadius": 4 },
  "encoding": {
    "x": {
      "field": "decade",
      "type": "ordinal",
      "axis": { "title": "Decade", "labelAngle": -30, "format": "d", "labelFontSize": 10 }
    },
    "y": {
      "field": "continent",
      "type": "nominal",
      "axis": { "title": null, "labelFontSize": 11 },
      "sort": ["Europe", "Americas", "Asia", "Oceania", "Africa"]
    },
    "color": {
      "field": "games_count",
      "type": "quantitative",
      "scale": { "scheme": "blues" },
      "legend": { "title": "Games Hosted" }
    },
    "tooltip": [
      { "field": "continent",   "type": "nominal",      "title": "Continent" },
      { "field": "decade",      "type": "ordinal",      "title": "Decade" },
      { "field": "games_count", "type": "quantitative", "title": "Games Hosted" }
    ]
  }
}
