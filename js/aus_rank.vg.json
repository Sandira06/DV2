{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 280,
  "config": {
    "background": "transparent",
    "view": { "stroke": "transparent" },
    "axis": {
      "labelColor": "#c8c0b0",
      "titleColor": "#c8c0b0",
      "gridColor":  "#2a2a3e",
      "domainColor": "#3a3a5e"
    },
    "legend": { "labelColor": "#c8c0b0", "titleColor": "#c8c0b0" }
  },
  "data": { "url": "js/aus_perf.csv", "format": { "type": "csv" } },
  "transform": [{ "filter": "datum.total > 0" }],
  "layer": [
    {
      "mark": { "type": "area", "opacity": 0.2, "color": "#f4b942", "line": false },
      "encoding": {
        "x": { "field": "year", "type": "quantitative", "axis": { "title": null, "format": "d" } },
        "y": { "field": "total", "type": "quantitative", "axis": { "title": "Medals Won", "orient": "left" } }
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#f4b942",
        "strokeWidth": 3,
        "point": { "filled": true, "size": 80, "color": "#f4b942", "stroke": "#ffffff", "strokeWidth": 1 }
      },
      "encoding": {
        "x": { "field": "year",  "type": "quantitative", "axis": { "title": null, "format": "d" } },
        "y": { "field": "total", "type": "quantitative", "axis": null },
        "tooltip": [
          { "field": "year",   "type": "quantitative", "title": "Year" },
          { "field": "gold",   "type": "quantitative", "title": "Gold" },
          { "field": "silver", "type": "quantitative", "title": "Silver" },
          { "field": "bronze", "type": "quantitative", "title": "Bronze" },
          { "field": "total",  "type": "quantitative", "title": "Total" },
          { "field": "rank",   "type": "quantitative", "title": "Rank" }
        ]
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#e07b54",
        "strokeWidth": 2,
        "strokeDash": [5, 3],
        "point": { "filled": true, "size": 50, "color": "#e07b54" }
      },
      "encoding": {
        "x": { "field": "year", "type": "quantitative" },
        "y": {
          "field": "rank",
          "type": "quantitative",
          "scale": { "domain": [35, 1] },
          "axis": { "title": "Final Rank", "orient": "right" }
        }
      }
    },
    {
      "data": { "values": [{ "year": 1981, "label": "AIS Founded" }] },
      "layer": [
        {
          "mark": { "type": "rule", "color": "#7ec8e3", "strokeWidth": 1.5, "strokeDash": [4, 3], "opacity": 0.7 },
          "encoding": {
            "x": { "field": "year", "type": "quantitative" }
          }
        },
        {
          "mark": { "type": "text", "align": "left", "baseline": "top", "fontSize": 9, "fontWeight": "bold", "color": "#7ec8e3", "dx": 4, "dy": 4 },
          "encoding": {
            "x":    { "field": "year",  "type": "quantitative" },
            "y":    { "datum": 60 },
            "text": { "field": "label" }
          }
        }
      ]
    },
    {
      "data": { "values": [{ "year": 2000, "label": "Sydney 2000", "total": 58 }] },
      "mark": { "type": "text", "align": "center", "baseline": "bottom", "fontSize": 9, "fontWeight": "bold", "color": "#f9d278", "dy": -6 },
      "encoding": {
        "x":    { "field": "year",  "type": "quantitative" },
        "y":    { "field": "total", "type": "quantitative", "axis": null },
        "text": { "field": "label" }
      }
    },
    {
      "data": { "values": [{ "year": 1976, "label": "0 Gold", "total": 5 }] },
      "mark": { "type": "text", "align": "center", "baseline": "bottom", "fontSize": 9, "fontStyle": "italic", "color": "#e07b54", "dy": -6 },
      "encoding": {
        "x":    { "field": "year",  "type": "quantitative" },
        "y":    { "field": "total", "type": "quantitative", "axis": null },
        "text": { "field": "label" }
      }
    }
  ],
  "resolve": { "scale": { "y": "independent" } }
}
