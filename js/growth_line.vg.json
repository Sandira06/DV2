{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 320,
  "config": {
    "background": "transparent",
    "view": { "stroke": "transparent" },
    "axis": {
      "labelColor": "#c8c0b0",
      "titleColor": "#c8c0b0",
      "gridColor":  "#2a2a3e",
      "domainColor": "#3a3a5e"
    },
    "legend": { "labelColor": "#c8c0b0", "titleColor": "#c8c0b0" }
  },
  "data": { "url": "js/history_data.csv", "format": { "type": "csv" } },
  "transform": [{ "filter": "datum.season === 'Summer'" }],
  "layer": [
    {
      "mark": { "type": "area", "opacity": 0.15, "color": "#f4b942", "line": false },
      "encoding": {
        "x": { "field": "year", "type": "quantitative", "axis": { "title": null, "format": "d", "grid": false } },
        "y": { "field": "athletes", "type": "quantitative", "axis": { "title": "Athletes", "orient": "left" } }
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#f4b942",
        "strokeWidth": 2.5,
        "point": { "filled": true, "size": 50, "color": "#f4b942" }
      },
      "encoding": {
        "x": { "field": "year", "type": "quantitative", "axis": { "title": null, "format": "d" } },
        "y": { "field": "athletes", "type": "quantitative", "axis": null },
        "tooltip": [
          { "field": "year",         "type": "quantitative", "title": "Year" },
          { "field": "city",         "type": "nominal",      "title": "Host City" },
          { "field": "host_country", "type": "nominal",      "title": "Host Country" },
          { "field": "athletes",     "type": "quantitative", "title": "Athletes" },
          { "field": "nations",      "type": "quantitative", "title": "Nations" },
          { "field": "events",       "type": "quantitative", "title": "Events" }
        ]
      }
    },
    {
      "mark": {
        "type": "line",
        "color": "#7ec8e3",
        "strokeWidth": 2.5,
        "strokeDash": [6, 3],
        "point": { "filled": true, "size": 50, "color": "#7ec8e3" }
      },
      "encoding": {
        "x": { "field": "year", "type": "quantitative" },
        "y": {
          "field": "nations",
          "type": "quantitative",
          "axis": { "title": "Nations", "orient": "right" },
          "scale": { "domain": [0, 250] }
        }
      }
    }
  ],
  "resolve": { "scale": { "y": "independent" } }
}
